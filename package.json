{
  "name": "getinorder",
  "version": "1.0.0",
  "description": "Plataforma de gerenciamento de tarefas. ## Tecnologias utilizadas JavaScript, React, Next.js, HTML, TailwindCSS, Supabase.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
